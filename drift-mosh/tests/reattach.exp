#!/usr/bin/env expect -f
# Reattach test — KNOWN LIMITATION: under rude disconnect
# (SIGKILL the client, simulating a network loss), DRIFT's
# server-side transport doesn't time out the dead peer for
# ~30 s by default. Within that window, new handshakes from
# the same peer_id can get rejected or stall.
#
# This test verifies the POLITE path:
# 1. Client 1 runs, gets session_id.
# 2. Client 1 issues `exit` via a graceful shutdown path
#    (not used here — shell exits on `exit`, which kills the
#    session anyway). So we instead demonstrate an IMMEDIATE
#    reattach-from-fresh: connect, check that the session_id
#    comes back, and disconnect.
# 3. The `drift-mosh` launcher writes session_ids to disk and
#    passes them on subsequent connects — that path is
#    covered by the launcher's integration test.
#
# The full "network dies, session survives" story is verified
# manually in drift-mosh/README.md (see "Manual migration
# demo"). Automating it fully requires either tuning DRIFT's
# peer-timeout configs for this bench or exercising the
# client's graceful-shutdown path, which is planned work.

set timeout 15

set server_log "/tmp/drift-mosh-reattach-server.log"
exec rm -f $server_log
exec sh -c "../../target/release/drift-mosh-server --bind 127.0.0.1:0 --shell /bin/sh --keepalive-secs 30 >$server_log 2>&1 &"

set banner ""
for {set i 0} {$i < 20} {incr i} {
    after 200
    if {[file exists $server_log]} {
        set banner [exec cat $server_log]
        if {[regexp {DRIFT_MOSH_PUB=([a-f0-9]+).*DRIFT_MOSH_ADDR=([0-9\.:]+)} $banner _ pub addr]} {
            break
        }
    }
}
if {![info exists pub]} {
    puts "FAIL: no banner"
    exit 1
}

# Run the client once, confirm we get a session_id back.
# The `drift-mosh` launcher persists it to disk; here we just
# check the line appeared.
spawn ../../target/release/drift-mosh-client --server-pub $pub --server-addr $addr

set session_id ""
expect {
    -re "DRIFT_MOSH_SESSION_ID=(\[0-9a-f]+)" {
        set session_id $expect_out(1,string)
    }
    timeout { puts "FAIL: no SESSION_ID line"; exit 1 }
}

if {[string length $session_id] != 32} {
    puts "FAIL: session_id should be 32 hex chars, got length [string length $session_id]"
    exit 1
}
puts "PASS: session_id well-formed: $session_id"

# End-to-end check that the protocol exchange works too.
expect -re {[\$#] *}
send "echo MARKER\r"
expect {
    "MARKER" { puts "PASS: echo through session works" }
    timeout  { puts "FAIL: no echo round-trip"; exit 1 }
}

send "exit\r"
expect eof
catch {exec pkill -f drift-mosh-server}
puts "ALL GOOD"
exit 0
